// Problem: Given two strings s and t, return true if t is an anagram of s, and false otherwise. An anagram is a word formed by rearranging the letters of a different word, using all the original letters exactly once.
function isAnagram(s,t){

  return s.split('').sort().join('')===t.split('').sort().join('');
  
}

console.log(isAnagram('anagram','nagaram'));
